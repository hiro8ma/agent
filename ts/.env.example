# agent/ts で使う API キー
#
# 使い方
#   1. このファイルを .env としてコピー
#        cp .env.example .env
#   2. 利用するプロバイダーのキーだけ埋める（全部必須ではない）
#   3. Bun は .env を自動で読み込むため、process.env.* で参照可能
#   4. .env は .gitignore に登録済、コミットしない
#
# キー取得ページ
#   OpenAI            https://platform.openai.com/api-keys
#   Anthropic         https://console.anthropic.com/settings/keys
#   Google AI Studio  https://aistudio.google.com/apikeys

# Anthropic Messages API（ts-phase1 既存実装で使用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Chat Completions / Responses API（ts-phase2 候補で使用予定）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API（ts-phase2 候補で使用予定）
GOOGLE_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxx

# プロバイダー / モデル切替（factory.ts のデフォルトは anthropic + claude-haiku-4-5-20251001）
# LLM_PROVIDER=anthropic     # anthropic / openai / google（実装次第）
# LLM_MODEL=claude-haiku-4-5-20251001
#
# 軽量モデル（推奨、ハンズオン / 動作確認向き）
#   anthropic  claude-haiku-4-5-20251001
#   openai     gpt-5-mini
#   google     gemini-2.5-flash
#
# 高性能モデル（複雑な推論 / 大規模リファクタ向き、コスト高 / レイテンシ大）
#   anthropic  claude-sonnet-4-6
#   anthropic  claude-opus-4-7（最強だが高価）
#   openai     gpt-5
#   google     gemini-2.5-pro
