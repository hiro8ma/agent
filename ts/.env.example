# agent/ts で使う API キー
#
# 使い方
#   1. このファイルを .env としてコピー
#        cp .env.example .env
#   2. 利用するプロバイダーのキーだけ埋める（全部必須ではない）
#   3. Bun は .env を自動で読み込むため、process.env.* で参照可能
#   4. .env は .gitignore に登録済、コミットしない
#
# キー取得ページ
#   OpenAI            https://platform.openai.com/api-keys
#   Anthropic         https://console.anthropic.com/settings/keys
#   Google AI Studio  https://aistudio.google.com/apikeys

# Anthropic Messages API（ts-phase1 既存実装で使用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Chat Completions / Responses API（ts-phase2 候補で使用予定）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API（ts-phase2 候補で使用予定）
GOOGLE_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxx
