# === LLM プロバイダ ===

# OpenAI（デフォルト。LLM_PROVIDER=openai）
OPENAI_API_KEY=your-openai-api-key-here

# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# === web_researcher エージェント ===

# Tavily Web 検索（web_search ツール）
TAVILY_API_KEY=your-tavily-api-key-here

# === mcp_client エージェント（agent/ ↔ mcp/ 連携） ===

# mcp/ リポジトリの場所。未設定なら agent/ の隣の mcp/ を自動検出する。
# MCP_REPO_PATH=/path/to/mcp
