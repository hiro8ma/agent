# LLM provider selector
#   openai （既定） / google
LLM_PROVIDER=openai

# モデル ID 明示（未指定なら provider 既定）
#   openai: gpt-4o-mini など / google: gemini-2.5-flash など
# LLM_MODEL=gpt-4o-mini

# API キー（provider に応じて必要なものだけ設定する。生キーはコミット禁止）
OPENAI_API_KEY=your-openai-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Confluence ツール（外部システム連携トラック）
#   BASE_URL は wiki まで含める。USER_EMAIL は Atlassian アカウント。
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USER_EMAIL=your-email@example.com
# API_TOKEN は記号を含むことがあるためダブルクォートで囲む
CONFLUENCE_API_TOKEN="your-confluence-api-token"
